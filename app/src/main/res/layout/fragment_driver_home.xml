<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Full-screen map ── -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ── Driver pulse marker overlay (positioned by Kotlin) ── -->
    <View
        android:id="@+id/pulseView"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_driver_pulse"
        android:visibility="gone"/>

    <!-- ── Top scrim gradient ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@drawable/bg_map_top_scrim"
        android:layout_gravity="top"/>

    <!-- ── Top driver info card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#EE0F0F1A"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <!-- Avatar + Name + Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <!-- Red border ring (always visible behind image/initial) -->
                    <View
                        android:id="@+id/avatarRing"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_driver_avatar"/>

                    <!-- Profile Image (circular, sits inside the border) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        android:visibility="gone" />

                    <!-- Initial letter fallback (sits inside the border) -->
                    <TextView
                        android:id="@+id/tvProfileInitial"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_driver_avatar_inner"
                        android:gravity="center"
                        android:text="D"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium"/>

                    <!-- Online status dot -->
                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_status_dot_offline"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"/>

                </FrameLayout>

                <!-- Name + status text -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="@color/divider_color"
                android:layout_marginHorizontal="14dp"
                android:alpha="0.5"/>

            <!-- Earnings block -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvEarnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="@color/success_color"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── GPS FAB ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="310dp"
        android:src="@drawable/bg_my_location_icon"
        app:backgroundTint="#EDE5E5"
        app:tint="@color/driver_color"
        app:fabSize="mini"
        app:elevation="8dp"/>

    <!-- ══════════════════════════════════════════════
         BOTTOM SHEET
    ══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_ride_confirm_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- ── Status section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="20dp">

                <!-- Animated status icon ring -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="14dp">

                    <!-- Outer ring -->
                    <View
                        android:id="@+id/statusRingOuter"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_status_ring_offline"/>

                    <!-- Inner icon -->
                    <ImageView
                        android:id="@+id/ivStatusIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:alpha="0.6"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/tvStatusMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You are currently offline"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvStatusSubMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Go online to start receiving ride requests"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- ── GO ONLINE / OFFLINE button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleOnline"
                style="@style/ChalRide.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="20dp"
                android:text="GO ONLINE"
                android:textSize="15sp"
                android:letterSpacing="0.06"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="@color/success_color"
                app:cornerRadius="16dp"/>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:alpha="0.5"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="18dp"/>

            <!-- ── Stats row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <!-- Trips today -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvTripsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trips"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Hours online -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvHoursOnline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Online"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/brand_primary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>