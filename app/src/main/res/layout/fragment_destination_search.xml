<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View
        android:id="@+id/pickupPulseView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_pulse_circle"
        android:visibility="gone"/>

    <View
        android:id="@+id/pulseView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_pulse_red"
        android:visibility="gone"/>

    <!-- ✅ MAP (MUST BE FIRST → background layer) -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapFullView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ✅ SEARCH BAR -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearchBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="14dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Pickup row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:layout_marginEnd="10dp"
                    android:alpha="0.7"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_pickup_dot"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvPickupInSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Current Location"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginStart="48dp"
                android:layout_marginBottom="8dp"/>

            <!-- Destination row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_destination_dot"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="10dp"/>

                <EditText
                    android:id="@+id/etDestinationSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Search destination"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@null"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/btnClearSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:alpha="0.5"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ✅ DROPDOWN -->
    <ListView
        android:id="@+id/lvDestinationResults"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxHeight="220dp"
        android:background="@drawable/bg_dropdown"
        android:elevation="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cardSearchBar"
        app:layout_constraintStart_toStartOf="@id/cardSearchBar"
        app:layout_constraintEnd_toEndOf="@id/cardSearchBar"/>

    <!-- ✅ GPS FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabGps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@color/bg_card"
        app:tint="@color/brand_primary"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmLocation"/>

    <TextView
        android:id="@+id/tvRouteInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_role_badge"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmLocation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- ✅ CONFIRM BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmLocation"
        style="@style/ChalRide.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Confirm Destination"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>