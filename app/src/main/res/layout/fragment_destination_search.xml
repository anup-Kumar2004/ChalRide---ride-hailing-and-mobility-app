<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View
        android:id="@+id/pickupPulseView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_pulse_circle"
        android:visibility="gone"/>

    <View
        android:id="@+id/pulseView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_pulse_red"
        android:visibility="gone"/>

    <!-- MAP — full screen background layer -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapFullView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SEARCH CARD — dropdown lives inside here, no gap possible -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearchBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="14dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pickup row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:layout_marginEnd="10dp"
                    android:alpha="0.7"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_pickup_dot"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvPickupInSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Current Location"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

            </LinearLayout>

            <!-- Divider between pickup and destination rows -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginStart="48dp"
                android:layout_marginBottom="8dp"/>

            <!-- Destination row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_destination_dot"
                    android:layout_marginStart="38dp"
                    android:layout_marginEnd="10dp"/>

                <EditText
                    android:id="@+id/etDestinationSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Search destination"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@null"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:cursorVisible="false"/>

                <ImageView
                    android:id="@+id/btnClearSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:alpha="0.5"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Divider shown only when dropdown or no-results is visible -->
            <View
                android:id="@+id/dividerDropdown"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_destination_dot"
                android:visibility="gone"/>

            <!-- Dropdown list — inside the card, zero gap -->
            <ListView
                android:id="@+id/lvDestinationResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="220dp"
                android:scrollbars="none"
                android:divider="@color/divider_color"
                android:dividerHeight="1dp"
                android:visibility="gone"/>

            <!-- No results empty state — also inside the card -->
            <LinearLayout
                android:id="@+id/cardNoResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="24sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No locations found"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvNoResultsQuery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="50dp"
        android:visibility="gone"
        app:cardBackgroundColor="#2A1A1A"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"

        app:layout_constraintBottom_toTopOf="@+id/btnConfirmLocation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#FF5252"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Warning Icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_marginStart="5dp"
                android:text="⚠️"
                android:textSize="14sp" />

            <!-- Message -->
            <TextView
                android:id="@+id/tvWarningMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- GPS FAB — constrained to btnConfirmLocation (unchanged) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabGps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="58dp"
        android:src="@drawable/bg_my_location_icon"
        app:backgroundTint="#EDE5E5"
        app:tint="#32E091"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmLocation"/>

    <!-- Change Destination button — constrained to btnConfirmLocation (unchanged) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangeDestination"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Change Destination"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/bg_role_badge"
        android:visibility="gone"
        android:elevation="8dp"
        android:layout_marginBottom="8dp"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmLocation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Route info pill — constrained to btnConfirmLocation (unchanged) -->
    <TextView
        android:id="@+id/tvRouteInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_role_badge"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmLocation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Confirm button — anchor for all bottom elements (unchanged) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmLocation"
        style="@style/ChalRide.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:clickable="true"
        android:focusable="true"
        android:text="Confirm Destination"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>