<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Full screen map ── -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ────────────────────────────────────────────
         TOP NAV HEADER — destination + phase tag
    ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topNavCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_dark"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Phase tag -->
        <TextView
            android:id="@+id/tvPhaseTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TO PICKUP"
            android:textColor="@color/brand_primary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.14"
            android:layout_marginBottom="4dp"/>

        <!-- Destination label -->
        <TextView
            android:id="@+id/tvDestLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fetching address..."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Distance · ETA -->
        <TextView
            android:id="@+id/tvDistEta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculating..."
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ── Arrival toast bar — appears above bottom bar on arrival ── -->
    <TextView
        android:id="@+id/tvArrivedBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="You have arrived!"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:background="#CC32E091"
        android:paddingVertical="10dp"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Bottom bar — Back + Recenter + Arrived action ── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_dark"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back to overview -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Overview"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:strokeColor="@color/divider_color"
            app:cornerRadius="12dp"
            android:layout_marginEnd="10dp"/>

        <!-- Recenter -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnRecenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/bg_my_location_icon"
            app:backgroundTint="@color/input_bg"
            app:tint="@color/brand_primary"
            app:fabSize="mini"
            android:layout_marginEnd="10dp"/>

        <!-- Arrived / Complete action (hidden until arrival detected) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrivedAction"
            style="@style/ChalRide.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Arrived at Pickup →"
            android:textSize="14sp"
            android:visibility="gone"
            app:cornerRadius="14dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>