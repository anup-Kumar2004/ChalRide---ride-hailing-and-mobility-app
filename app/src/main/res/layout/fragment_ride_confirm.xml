<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Full-screen Map ── -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapRoutePreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Top scrim gradient ── -->
    <View
        android:id="@+id/topScrim"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_map_top_scrim"
        android:layout_gravity="top" />

    <!-- ── Top bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp"
        android:layout_gravity="top">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:alpha="0.85"
            android:layout_marginEnd="14dp"
            android:padding="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Ride"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.01" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════
         BOTTOM SHEET
         peekHeight is set in Kotlin to (screenHeight * 0.24)
    ═══════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_ride_confirm_sheet"
        android:elevation="20dp"
        android:layout_gravity="bottom"
        android:fillViewport="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="180dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.55"
        app:behavior_expandedOffset="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ── Drag handle ── -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_drag_handle" />

            <!-- ══════════════════════════════════════════════════════
                 ROUTE SUMMARY
            ══════════════════════════════════════════════════════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingBottom="16dp">

                <View
                    android:id="@+id/dotPickup"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_online"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvPickupAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvPickupAddress" />

                <View
                    android:id="@+id/connectorLine"
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:background="@color/text_hint"
                    android:alpha="0.30"
                    app:layout_constraintStart_toStartOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toBottomOf="@id/dotPickup"
                    app:layout_constraintBottom_toTopOf="@id/dotDest" />

                <View
                    android:id="@+id/dotDest"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_destination_dot"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvDestAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvDestAddress" />

                <TextView
                    android:id="@+id/labelPickup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="PICKUP"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="2dp"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintEnd_toStartOf="@id/chipStack"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPickupAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.25"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintEnd_toStartOf="@id/chipStack"
                    app:layout_constraintTop_toBottomOf="@id/labelPickup" />

                <TextView
                    android:id="@+id/labelDropoff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="DROP-OFF"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="2dp"
                    app:layout_constraintStart_toEndOf="@id/dotDest"
                    app:layout_constraintEnd_toStartOf="@id/chipStack"
                    app:layout_constraintTop_toBottomOf="@id/tvPickupAddress" />

                <TextView
                    android:id="@+id/tvDestAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.25"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toEndOf="@id/dotDest"
                    app:layout_constraintEnd_toStartOf="@id/chipStack"
                    app:layout_constraintTop_toBottomOf="@id/labelDropoff" />

                <LinearLayout
                    android:id="@+id/chipStack"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_role_badge"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_distance"
                            android:layout_marginEnd="5dp"
                            app:tint="@color/text_hint" />

                        <TextView
                            android:id="@+id/tvRouteDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_role_badge">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_eta"
                            android:layout_marginEnd="5dp"
                            app:tint="@color/text_hint" />

                        <TextView
                            android:id="@+id/tvRouteEta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_hint"
                android:alpha="0.10"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="14dp" />

            <!-- ── "Choose a ride" heading row with driver count badge ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose a ride"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01" />

                <!-- Live driver count badge — updated from Kotlin -->
                <TextView
                    android:id="@+id/tvDriverCountBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Searching..."
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════════════
                 VEHICLE CARDS — all 4 always visible.
                 Available  → normal colors, clickable, fare shown
                 Unavailable → dimmed overlay, NOT clickable, "Not available" badge

                 Each card is a FrameLayout so the "Not available" scrim overlay
                 can be stacked precisely on top of the card content.
            ══════════════════════════════════════════════════════════════ -->

            <!-- ── BIKE card ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp">

                <!-- Card content -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBike"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <!-- Emoji icon -->
                        <TextView
                            android:id="@+id/tvBikeEmoji"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🏍️"
                            android:textSize="24sp"
                            android:gravity="center" />

                        <!-- Name + subtitle -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvBikeName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bike"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvBikeSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fastest · 1 seat"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <!-- Right side: fare OR "Not available" pill -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end|center_vertical">

                            <TextView
                                android:id="@+id/tvBikeFare"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/brand_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                            <!-- "Not available" badge — hidden when available -->
                            <TextView
                                android:id="@+id/tvBikeUnavailable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not available"
                                android:textColor="#FF5C5C"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:background="@drawable/bg_unavailable_badge"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Disabled scrim overlay — shown on top when unavailable -->
                <View
                    android:id="@+id/scrimBike"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scrim_rounded"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ── AUTO card ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAuto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:id="@+id/tvAutoEmoji"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🛺"
                            android:textSize="24sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvAutoName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvAutoSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Affordable · 3 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end|center_vertical">

                            <TextView
                                android:id="@+id/tvAutoFare"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/brand_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvAutoUnavailable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not available"
                                android:textColor="#FF5C5C"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:background="@drawable/bg_unavailable_badge"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/scrimAuto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scrim_rounded"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ── SEDAN card ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSedan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:id="@+id/tvSedanEmoji"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🚗"
                            android:textSize="24sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvSedanName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sedan"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvSedanSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comfortable · 4 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end|center_vertical">

                            <TextView
                                android:id="@+id/tvSedanFare"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/brand_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvSedanUnavailable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not available"
                                android:textColor="#FF5C5C"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:background="@drawable/bg_unavailable_badge"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/scrimSedan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scrim_rounded"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ── SUV card ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSuv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:id="@+id/tvSuvEmoji"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🚙"
                            android:textSize="24sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvSuvName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SUV"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvSuvSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Premium · 6 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end|center_vertical">

                            <TextView
                                android:id="@+id/tvSuvFare"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/brand_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvSuvUnavailable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not available"
                                android:textColor="#FF5C5C"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:background="@drawable/bg_unavailable_badge"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/scrimSuv"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scrim_rounded"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ── Find a Ride button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindRide"
                style="@style/ChalRide.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:text="Find a Ride" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>