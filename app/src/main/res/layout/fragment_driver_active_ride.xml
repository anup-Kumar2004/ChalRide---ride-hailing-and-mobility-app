<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Locked mini-map (top ~55% of screen) ── -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top scrim gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_map_top_scrim"
        android:layout_gravity="top"/>

    <!-- Top label card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTopLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#EE0F0F1A"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tvPhaseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEADING TO PICKUP"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"/>

            <TextView
                android:id="@+id/tvCurrentTarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Navigate FAB-style button — appears after route is drawn -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavigate"
        style="@style/ChalRide.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="310dp"
        android:text="▲  Navigate to Pickup"
        android:paddingHorizontal="20dp"
        android:textSize="14sp"
        android:visibility="gone"
        android:elevation="10dp"
        app:cornerRadius="26dp"
        app:backgroundTint="@color/bg_card"/>

    <!-- ══════════════════════════
         BOTTOM DETAILS SHEET
    ══════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_ride_confirm_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- Fare + vehicle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvFare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="₹0"
                    android:textColor="@color/success_color"
                    android:textSize="30sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvVehicleType"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/bg_role_badge"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="AUTO"/>

            </LinearLayout>

            <!-- Rider name row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_driver_avatar_inner"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvRiderName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Rider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CASH"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_role_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:alpha="0.4"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="16dp"/>

            <!-- Route summary -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/dotPickup"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_online"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvPickupAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvPickupAddress"/>

                <View
                    android:id="@+id/connectorLine"
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:background="@color/text_hint"
                    android:alpha="0.3"
                    app:layout_constraintStart_toStartOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toBottomOf="@id/dotPickup"
                    app:layout_constraintBottom_toTopOf="@id/dotDest"/>

                <View
                    android:id="@+id/dotDest"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_destination_dot"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvDestAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvDestAddress"/>

                <TextView
                    android:id="@+id/tvPickupAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginStart="14dp"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvDestAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="14dp"
                    app:layout_constraintStart_toEndOf="@id/dotDest"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPickupAddress"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>