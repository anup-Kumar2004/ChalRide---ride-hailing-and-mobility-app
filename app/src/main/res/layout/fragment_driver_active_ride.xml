<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Full screen map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_map_top_scrim"
        android:layout_gravity="top"/>

    <!-- Top status card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#EE0F0F1A"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <!-- Status label -->
            <TextView
                android:id="@+id/tvTripStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEADING TO PICKUP"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"/>

            <!-- Rider name + distance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvRiderName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rider"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvDistanceToPickup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- km"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Address -->
            <TextView
                android:id="@+id/tvCurrentTarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fetching address..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB my location -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="220dp"
        android:src="@drawable/bg_my_location_icon"
        app:backgroundTint="#EDE5E5"
        app:tint="@color/driver_color"
        app:fabSize="mini"
        app:elevation="8dp"/>

    <!-- Bottom action sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_ride_confirm_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- Fare + vehicle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvFare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="₹0"
                    android:textColor="@color/success_color"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvVehicleType"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/bg_role_badge"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="AUTO"/>

            </LinearLayout>

            <!-- Route summary -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/dotPickup"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_online"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvPickupAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvPickupAddress"/>

                <View
                    android:id="@+id/connectorLine"
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:background="@color/text_hint"
                    android:alpha="0.3"
                    app:layout_constraintStart_toStartOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toBottomOf="@id/dotPickup"
                    app:layout_constraintBottom_toTopOf="@id/dotDest"/>

                <View
                    android:id="@+id/dotDest"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_destination_dot"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvDestAddress"
                    app:layout_constraintBottom_toBottomOf="@id/tvDestAddress"/>

                <TextView
                    android:id="@+id/tvPickupAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginStart="14dp"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvDestAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="14dp"
                    app:layout_constraintStart_toEndOf="@id/dotDest"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPickupAddress"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:alpha="0.3"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="16dp"/>

            <!-- Action button — changes based on trip phase -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTripAction"
                style="@style/ChalRide.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:text="Arrived at Pickup"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>