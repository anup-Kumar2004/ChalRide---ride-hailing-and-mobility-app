<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- FULL SCREEN MAP -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- TOP PICKUP SEARCH CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPickupSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#EE1A1A2E"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/ivHamburger"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_more"
                    android:alpha="0.85"
                    android:layout_marginEnd="12dp"
                    android:padding="2dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot_online"
                    android:layout_marginEnd="10dp" />

                <EditText
                    android:id="@+id/etPickupSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fetching location..."
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:textColorHint="@color/text_hint" />

                <ProgressBar
                    android:id="@+id/progressLocation"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:indeterminateTint="@color/brand_primary"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Dropdown results list — hidden by default -->
            <ListView
                android:id="@+id/lvPickupResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="220dp"
                android:scrollbars="none"
                android:divider="@color/divider_color"
                android:dividerHeight="1dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- GPS FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="320dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@color/bg_card"
        app:tint="@color/brand_primary"
        app:fabSize="mini"
        app:elevation="8dp" />

    <!-- BOTTOM SHEET -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Where to?"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/input_bg"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_destination_dot"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvDestinationHint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Search destination..."
                        android:textColor="@color/text_hint"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:alpha="0.4" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Select"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 Home"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💼 Work"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAirport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✈️ Airport"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvChooseRide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose a ride"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutVehicles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBike"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🏍️"
                            android:textSize="26sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bike"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fastest · 1 seat"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBikeFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAuto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🛺"
                            android:textSize="26sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Affordable · 3 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAutoFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSedan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🚗"
                            android:textSize="26sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sedan"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comfortable · 4 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSedanFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSuv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🚙"
                            android:textSize="26sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SUV"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Premium · 6 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSuvFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindRide"
                style="@style/ChalRide.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Find a Ride"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>