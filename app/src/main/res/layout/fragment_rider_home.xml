<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Map takes top 35% -->
    <LinearLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:orientation="vertical">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="260dp"/>
    </LinearLayout>

    <!-- FAB over map -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="210dp"
        android:layout_marginEnd="12dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@color/bg_card"
        app:tint="@color/brand_primary"
        app:fabSize="mini"
        app:elevation="6dp"/>

    <!-- Bottom sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="260dp"
        android:background="@drawable/bg_bottom_sheet"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- Pickup row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/bg_pickup_dot"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvPickupLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fetching location..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <ProgressBar
                    android:id="@+id/progressLocation"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminateTint="@color/brand_primary"/>
            </LinearLayout>

            <!-- Vertical line connecting dots -->
            <View
                android:layout_width="2dp"
                android:layout_height="16dp"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="10dp"
                android:background="@color/divider_color"/>

            <!-- Destination search card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/input_bg"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_destination_dot"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/tvDestinationHint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Where are you going?"
                        android:textColor="@color/text_hint"
                        android:textSize="15sp"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:alpha="0.5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick destinations label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Select"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <!-- Quick destination chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 Home"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💼 Work"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAirport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✈️ Airport"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/input_bg"
                    app:chipStrokeColor="@color/divider_color"
                    app:chipStrokeWidth="1dp"/>
            </LinearLayout>

            <!-- Vehicle selector label -->
            <TextView
                android:id="@+id/tvChooseRide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose a ride"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Vehicle cards -->
            <LinearLayout
                android:id="@+id/layoutVehicles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <!-- 2 Wheeler -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBike"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🏍️"
                            android:textSize="28sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bike"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fastest · 1 seat"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvBikeFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Auto -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAuto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🛺"
                            android:textSize="28sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Affordable · 3 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvAutoFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sedan -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSedan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🚗"
                            android:textSize="28sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sedan"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comfortable · 4 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvSedanFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- SUV -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSuv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="🚙"
                            android:textSize="28sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SUV"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Premium · 6 seats"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvSuvFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹--"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Find Ride Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindRide"
                style="@style/ChalRide.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Find a Ride"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>