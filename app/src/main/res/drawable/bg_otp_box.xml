<?xml version="1.0" encoding="utf-8"?>
<!-- OTP digit box — rounded rectangle with brand border -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state — highlighted border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1E1E35"/>
            <corners android:radius="12dp"/>
            <stroke android:width="2dp" android:color="#6C63FF"/>
        </shape>
    </item>

    <!-- Filled state (has text) -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="#1E1E35"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1.5dp" android:color="#2A2A45"/>
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E1E35"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1.5dp" android:color="#2A2A45"/>
        </shape>
    </item>

</selector>