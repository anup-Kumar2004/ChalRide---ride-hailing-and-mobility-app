<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/roleSelectionFragment">

    <fragment
        android:id="@+id/roleSelectionFragment"
        android:name="com.example.chalride.ui.auth.RoleSelectionFragment"
        android:label="RoleSelectionFragment">
        <action
            android:id="@+id/action_role_to_login"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.chalride.ui.auth.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
        <action
            android:id="@+id/action_login_to_rider_home"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_login_to_driver_home"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_login_to_driver_profile_setup"
            app:destination="@id/driverProfileSetupFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.chalride.ui.auth.RegisterFragment"
        android:label="RegisterFragment">
        <action
            android:id="@+id/action_register_to_rider_home"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_register_to_driver_profile_setup"
            app:destination="@id/driverProfileSetupFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ══ DRIVER SETUP FLOW ══════════════════════════════════════ -->

    <fragment
        android:id="@+id/driverProfileSetupFragment"
        android:name="com.example.chalride.ui.driver.DriverProfileSetupFragment"
        android:label="DriverProfileSetupFragment">
        <action
            android:id="@+id/action_driverProfileSetup_to_driverVehicleSetup"
            app:destination="@id/driverVehicleSetupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/driverVehicleSetupFragment"
        android:name="com.example.chalride.ui.driver.DriverVehicleSetupFragment"
        android:label="DriverVehicleSetupFragment">
        <action
            android:id="@+id/action_driverVehicleSetup_to_driverHome"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ══ MAIN SCREENS ══════════════════════════════════════════ -->

    <fragment
        android:id="@+id/riderHomeFragment"
        android:name="com.example.chalride.ui.rider.RiderHomeFragment"
        android:label="RiderHomeFragment">
        <action
            android:id="@+id/action_rider_home_to_destination_search"
            app:destination="@id/destinationSearchFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/driverHomeFragment"
        android:name="com.example.chalride.ui.driver.DriverHomeFragment"
        android:label="DriverHomeFragment">
        <action
            android:id="@+id/action_driverHome_to_driverActiveRide"
            app:destination="@id/driverActiveRideFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>


    <fragment
        android:id="@+id/destinationSearchFragment"
        android:name="com.example.chalride.ui.rider.DestinationSearchFragment"
        android:label="DestinationSearchFragment">
        <action
            android:id="@+id/action_destination_search_to_ride_confirm"
            app:destination="@id/rideConfirmFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- ── rideConfirmFragment — action to rideSearching added ── -->
    <fragment
        android:id="@+id/rideConfirmFragment"
        android:name="com.example.chalride.ui.rider.RideConfirmFragment"
        android:label="RideConfirmFragment">
        <action
            android:id="@+id/action_rideConfirm_to_rideSearching"
            app:destination="@id/rideSearchingFragment"
            app:popUpTo="@id/rideConfirmFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>

    <fragment
        android:id="@+id/rideSearchingFragment"
        android:name="com.example.chalride.ui.rider.RideSearchingFragment"
        android:label="RideSearchingFragment">
        <action
            android:id="@+id/action_rideSearching_to_rideLive"
            app:destination="@id/rideLiveFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_rideSearching_to_riderHome"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/rideLiveFragment"
        android:name="com.example.chalride.ui.rider.RideLiveFragment"
        android:label="RideLiveFragment">
        <action
            android:id="@+id/action_rideLive_to_riderHome"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/driverActiveRideFragment"
        android:name="com.example.chalride.ui.driver.DriverActiveRideFragment"
        android:label="DriverActiveRideFragment">
        <action
            android:id="@+id/action_driverActiveRide_to_driverNavigation"
            app:destination="@id/driverNavigationFragment"
            app:popUpTo="@id/driverNavigationFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
        <action
            android:id="@+id/action_driverActiveRide_to_driverHome"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_driverActiveRide_to_driverArrivedPickup"
            app:destination="@id/driverArrivedPickupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>

    </fragment>


    <fragment
        android:id="@+id/driverNavigationFragment"
        android:name="com.example.chalride.ui.driver.DriverNavigationFragment"
        android:label="DriverNavigationFragment">
        <action
            android:id="@+id/action_driverNavigation_to_driverArrivedPickup"
            app:destination="@id/driverArrivedPickupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_driverNavigation_to_driverHome"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/driverArrivedPickupFragment"
        android:name="com.example.chalride.ui.driver.DriverArrivedPickupFragment"
        android:label="DriverArrivedPickupFragment">
        <action
            android:id="@+id/action_driverArrivedPickup_to_driverActiveRide"
            app:destination="@id/driverActiveRideFragment"
            app:popUpTo="@id/driverActiveRideFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>


</navigation>