<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/roleSelectionFragment">

    <fragment
        android:id="@+id/roleSelectionFragment"
        android:name="com.example.chalride.ui.auth.RoleSelectionFragment"
        android:label="RoleSelectionFragment">
        <action
            android:id="@+id/action_role_to_login"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.chalride.ui.auth.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
        <action
            android:id="@+id/action_login_to_rider_home"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>

        <!--
            Driver login: check if profile is complete.
            If YES  → action_login_to_driver_home  (existing)
            If NO   → action_login_to_driver_profile_setup  (new)
            The LoginFragment.kt decides which action to fire.
        -->
        <action
            android:id="@+id/action_login_to_driver_home"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_login_to_driver_profile_setup"
            app:destination="@id/driverProfileSetupFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.chalride.ui.auth.RegisterFragment"
        android:label="RegisterFragment">

        <action
            android:id="@+id/action_register_to_rider_home"
            app:destination="@id/riderHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>

        <action
            android:id="@+id/action_register_to_driver_profile_setup"
            app:destination="@id/driverProfileSetupFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ══ DRIVER SETUP FLOW ══════════════════════════════════════ -->

    <fragment
        android:id="@+id/driverProfileSetupFragment"
        android:name="com.example.chalride.ui.driver.DriverProfileSetupFragment"
        android:label="DriverProfileSetupFragment">
        <action
            android:id="@+id/action_driverProfileSetup_to_driverVehicleSetup"
            app:destination="@id/driverVehicleSetupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/driverVehicleSetupFragment"
        android:name="com.example.chalride.ui.driver.DriverVehicleSetupFragment"
        android:label="DriverVehicleSetupFragment">
        <action
            android:id="@+id/action_driverVehicleSetup_to_driverHome"
            app:destination="@id/driverHomeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ══ MAIN SCREENS ══════════════════════════════════════════ -->

    <fragment
        android:id="@+id/riderHomeFragment"
        android:name="com.example.chalride.ui.rider.RiderHomeFragment"
        android:label="RiderHomeFragment">
        <action
            android:id="@+id/action_rider_home_to_destination_search"
            app:destination="@id/destinationSearchFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/driverHomeFragment"
        android:name="com.example.chalride.ui.driver.DriverHomeFragment"
        android:label="DriverHomeFragment"/>

    <fragment
        android:id="@+id/destinationSearchFragment"
        android:name="com.example.chalride.ui.rider.DestinationSearchFragment"
        android:label="DestinationSearchFragment">
        <action
            android:id="@+id/action_destination_search_to_ride_confirm"
            app:destination="@id/rideConfirmFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/rideConfirmFragment"
        android:name="com.example.chalride.ui.rider.RideConfirmFragment"
        android:label="RideConfirmFragment"/>

</navigation>